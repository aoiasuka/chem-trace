// 高校实验室危化品全流程追溯系统 —— 数据模型
// 团队共用：组长建主干，各成员维护自己的 model

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// 用户（成员E）
model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String // bcrypt 哈希
  realName String
  role     String @default("USER") // ADMIN / USER
}

// 危化品基础信息（成员A）
model Chemical {
  id              Int       @id @default(autoincrement())
  name            String
  casNo           String?
  category        String // 易制毒 / 易制爆 / 其他
  hazardDesc      String?
  msdsUrl         String?
  safeThreshold   Float     @default(0) // 安全阈值
  unit            String    @default("g")
  currentQuantity Float     @default(0) // 当前库存总量
  stockIns        StockIn[]
  opLogs          OpLog[]
}

// 入库记录（成员B）
model StockIn {
  id         Int      @id @default(autoincrement())
  chemical   Chemical @relation(fields: [chemicalId], references: [id])
  chemicalId Int
  batchNo    String
  supplier   String
  inQuantity Float
  operator   String
  inDate     DateTime @default(now())
}

// 领用/归还流水（成员C）
model OpLog {
  id         Int      @id @default(autoincrement())
  chemical   Chemical @relation(fields: [chemicalId], references: [id])
  chemicalId Int
  opType     String // 领用 / 归还 / 废弃
  operator   String
  quantity   Float
  opTime     DateTime @default(now())
}

// 审计日志（成员E）
model AuditLog {
  id       Int      @id @default(autoincrement())
  action   String // 增 / 删 / 改 / 查
  module   String
  operator String
  detail   String
  opTime   DateTime @default(now())
}
